rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }
    
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if request.auth != null && isAdmin();
    }
    
    match /groups/{groupId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // El documento singleton del torneo: admins escriben, todos leen
    match /tournament/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Equipos del torneo: todos los usuarios autenticados pueden leer/crear/actualizar
    // (se necesita para aceptar invitaciones de pareja)
    match /tournamentTeams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }

    // Config global (contraseña maestra, etc. — solo admins pueden escribir)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
